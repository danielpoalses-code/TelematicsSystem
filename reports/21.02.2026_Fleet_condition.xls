<html xmlns="http://www.w3.org/1999/xhtml" xmlns:svg="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink"><head><meta http-equiv="Content-Type" content="text/html; charset=utf-8"><style>

@page {
    size: A3 landscape;
    margin: 0.5cm;
}

.x-border-box, .x-border-box * {
    box-sizing: border-box;
    -moz-box-sizing: border-box;
    -ms-box-sizing: border-box;
    -webkit-box-sizing: border-box;
}

body, .x-body {
    font-family: tahoma, arial, verdana, sans-serif;
    padding: 0;
    box-sizing: border-box;
    margin: 0;
    background: transparent;
}

.x-box-inner, .x-box-target {
    width: 100% !important;
}

form {
    margin: 0;
}

table {
    width: 100%;
    border-collapse: collapse;
    border-spacing: 0;
}

.rlevel1 {
    font-size: 16px !important;
    background: #FFF;
    padding: 15px !important;
    text-transform: capitalize;
    width: 100%;
}

td.rlevel2, .rlevel2 {
    font-size: 14px !important;
    background-color: #e0e0e0;
    padding: 5px 5px 5px 15px !important;
    border-top: #ddd 1px solid;
    border-bottom: #ccc 1px solid;
    color: #111;
}

.rlevel3 {
    font-size: 14px !important;
    background: #eef5ff;
    padding: 5px 5px 5px 15px !important;
    border-bottom: #ccc 1px solid;
}

td.rlevel4, .rlevel4 {
    font-size: 14px;
    padding: 5px 5px 5px 15px !important;
    border-bottom: #ccc 1px solid;
    font-weight: bold;
    background-color: #FFF;
}

.rlevel5 {
    background-color: #FFF;
    position: sticky;
    top: 81px;
}

.rlevel5 th {
    border: #bbb 1px solid;
}

th {
    text-align: left;
}

.report_table1 {
    width: 100%;
    background: transparent;
}

.report_table1 th {
    padding: 5px;
    font-size: 12px;
    font-weight: bold;
    color: #444;
    text-align: left;
    border-right: #DDD 1px solid;
    border-top: #DDD 1px solid;
    border-bottom: #DDD 1px solid;
}

.report_table1 td {
    padding: 5px;
    font-size: 12px;
}

.report_table1 tr.rw {
    border-bottom: #ccc 1px solid;
}

.report_table1 tr.odd {
    background: #FAFAFA;
}

.gosnum {
    background: #fff;
    border: #000 1px solid;
    color: #333;
    -webkit-border-radius: 3px;
    border-radius: 3px;
    -moz-border-radius: 3px;
    display: inline-block;
    font-family: Helvetica;
    text-align: center;
    padding: 2px 4px 2px 4px;
    box-shadow: 0 0 3px rgba(0, 0, 0, 0.8);
    -moz-box-shadow: 0 0 3px rgba(0, 0, 0, 0.8);
    -webkit-box-shadow: 0 0 3px rgba(0, 0, 0, 0.8);
}

.chartdiv {
    height: 250px;
    width: 100%;
}

.piediv {
    height: 300px;
    width: 100%;
}

tr {
    page-break-inside: avoid
}

.report_summary {
    background: #ffffdd;
    font-weight: bold;
    white-space: nowrap;
    border-bottom: #ccc 1px solid;
}

.report_table1 tr.rw td {
    height: 24px;
}

.rag_r {
    background: #E5593C;
    color: #ffffff;
    text-align: right;
    line-height: 24px;
    padding: 5px;
    height: 100%;
}

.rag_a {
    background: #F6BE50;
    color: #ffffff;
    text-align: right;
    line-height: 24px;
    padding: 5px;
    height: 100%;
}

.rag_g {
    background: #68C656;
    color: #ffffff;
    text-align: right;
    line-height: 24px;
    padding: 5px;
    height: 100%;
}

.x-toolbar {
    display: none;
}

.x-panel-header {
    display: none;
}

.x-panel-body, .x-panel, .x-panel-bodyWrap {
    width: 100% !important;
    overflow: visible !important;
}

.x-panel-body-default {
    border: none;
    color: #575757;
}

.clps {
    border-bottom: #555 1px solid;
    border-top: #555 1px solid;
    background: #FFFFCC;
    font-weight: bold;
}

.rep_track {
    color: #000077;
    background-color: #ffffff;
    font-weight: normal;
}

.rep_track td:first-child {
    padding-left: 40px;
    background-position: 10px center;
}

.clps_child td:first-child {
    padding-left: 24px;
    background-image: url(../images/2px.png);
    background-position: left top;
    background-size: 12px;
    background-repeat: repeat-y;
}

.rep_parks {
    color: #622700;
    background-color: #EEEEEE;
}

.rep_parks td:first-child {
    padding-left: 50px;
    background-position: 20px, center;
}

.rep_park {
    color: #622700;
    background-color: #EEEEEE;
}

.rep_park td:first-child {
    padding-left: 50px;
}

.rep_zones {
    color: #990000;
    background-color: #EEEEEE;
}

.rep_zones td:first-child {
    padding-left: 50px;
    background-position: 20px, center;
}

.rep_zone {
    color: #990000;
    background-color: #EEEEEE;
}

.rep_zone td:first-child {
    padding-left: 50px;
}

.rep_notifys {
    color: #006200;
    background-color: #EEEEEE;
}

.rep_notifys td:first-child {
    padding-left: 50px;
    background-position: 20px, center;
}

.rep_notify {
    color: #006200;
    background-color: #EEEEEE;
}

.rep_notify td:first-child {
    padding-left: 50px;
}

.rep_move {
    color: #000077;
    background-color: #EEEEEE;
}

.rep_move td:first-child {
    padding-left: 50px;
}

.rep_idle {
    color: #857600;
    background-color: #EEEEEE;
}

.rep_idle td:first-child {
    padding-left: 50px;
}

.mv {
    background-color: #ffd;
}

.td_right {
    text-align: right !important;
    white-space: nowrap;
}

.td_center {
    text-align: center !important;
    white-space: nowrap;
}

.an_info_block{
    cursor: pointer;
    user-select: none;
    border-radius: 5px;
    box-shadow: 0 1px 7px rgba(0, 0, 0, 0.14);
}
.an_info_block:hover{
    cursor: pointer;
    box-shadow: 0px 0px 8px 5px #ccc;
}

.an_info_title{
    cursor: pointer;
    font-size: 13px;
    text-align: center;
    white-space: nowrap;
}

.an_info_value{
    cursor: pointer;
    line-height: 20px;
    font-weight: bold;
    font-size: 16px;
    white-space: nowrap;
    text-align: center;
}

.highcharts-container{
    border-radius: 5px;
    box-shadow: 0 1px 7px rgba(0, 0, 0, 0.14);
}

.highcharts-container:hover{
    cursor: pointer;
    box-shadow: 0px 0px 8px 5px #ccc;
}
.checkbox-white {
    border-color: white;
}
.checkbox-white .x-form-checkbox {
    border-color: white;
}
.checkbox-white .x-form-field {
    color: white;
}
.checkbox-white .x-form-cb-label {
    color: white;
    padding-left: 20px;
}

.din_eq,.din_low,.din_less,.din_more,.din_much,.rank_r,.rank_a,.rank_g{
    margin-right: 2px;
}
.din_eq:before{
    content: "\f52c";
    color:#6856C6;
}
.din_low:before{
    content: "\f103";
    color:#68C656;
}
.din_less:before{
    content: "\f103";
    color:#0077aa;
}
.din_more:before{
    content: "\f102";
    color:#F6BE50;
}
.din_much:before{
    content: "\f102";
    color:#E7593E;
}
.rank_g:before{
    content: "\f058";
    color:#68C656;
}
.rank_a:before{
    content: "\f071";
    color:#F6BE50;
}
.rank_r:before{
    content: "\f06a";
    color:#E7593E;
}
th.red_header {
    background-color:#E7593E;
    color:#fff;
    text-align: center;
}
th.green_header {
    background-color:#68C656;
    color:#fff;
    text-align: center;
}
th.grey_header {
    background-color: #c1c1c1;
    color:#fff;
    text-align: center;
}

@media print {
    .map-page-print {
        height: 1000px !important;
        overflow: hidden !important;
    }

    .break-after {
        page-break-after: always;
        break-after: page;
    }

    .map-container-print {
        height: auto !important;
        flex-grow: 1 !important;
    }
}

.report_table1 tr.mc.report_mc.trk td { 
    background-color: #0284c71a !important; 
    -webkit-print-color-adjust: exact !important;
    print-color-adjust: exact !important;
}


/* #region стили для отчета 71_BRAG_report -------------------------------------------------------------------------------*/

.brag-container {
    display: flex;
    gap: 15px;
    margin-top: 10px;
}
.brag-box {
    flex: 1;
    padding: 20px 10px;
    color: #000;
    text-align: center;
    border-radius: 4px;
    font-family: Arial, sans-serif;
    min-width: 0;
}
.brag-title {
    font-weight: bold;
    font-size: 18px;
    margin-bottom: 5px;
}
.brag-value {
    font-weight: bold;
    font-size: 20px;
}
.brag-percent {
    font-size: 14px;
    margin-top: 3px;
}
.brag-label {
    margin-top: 10px;
    font-size: 14px;
}

.brag-blue  { background: #4db2ff; }
.brag-green { background: #4caf50 }
.brag-amber { background: #ffeb3b }
.brag-red   { background: #f44336 }

/* ---------------- */
.section-header {
    background: #1e64c8;
    color: white;
    padding: 10px 15px;
    font-weight: bold;
    border-radius: 4px;
    margin-top: 20px;
    font-family: Arial, sans-serif;
}
/* Контейнер для 3-х блоков */
.brag-fps-container {
    display: flex;
    justify-content: space-between;
    gap: 20px;
    margin: 20px 0;
    font-family: Arial, sans-serif;
}
/* Каждый блок */
.brag-fps-box {
    flex: 1;
    background: #f9f9f9;
    padding: 20px 10px;
    border-radius: 6px;
    text-align: center;
    min-height: 80px;
}
.brag-fps-label {
    font-size: 14px;
    color: #555;
    margin-bottom: 8px;
}
.brag-fps-value {
    font-size: 20px;
    font-weight: bold;
    color: #1e64c8;
}      

/* #endregion стили для отчета 71_BRAG_report -------------------------------------------------------------------------------*/
