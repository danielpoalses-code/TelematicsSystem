rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function hasRole(role) {
      return isSignedIn() && getUserData().role == role;
    }
    
    function isKhuluAdmin() {
      return hasRole('khulu_admin');
    }

    // User profiles
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isKhuluAdmin();
    }

    // Dealerships
    match /dealerships/{dealershipId} {
      allow read: if isSignedIn();
      allow write: if isKhuluAdmin();
    }

    // Clients
    match /clients/{clientId} {
      allow read: if isSignedIn() && (
        isKhuluAdmin() || 
        getUserData().role == 'oem_manager' ||
        (getUserData().role == 'dealer_manager' && getUserData().dealershipId == resource.data.dealershipId) ||
        (getUserData().role == 'fleet_client' && getUserData().clientId == clientId)
      );
      allow write: if isKhuluAdmin() || getUserData().role == 'dealer_manager';
    }

    // Trucks
    match /trucks/{truckId} {
      allow read: if isSignedIn() && (
        isKhuluAdmin() || 
        getUserData().role == 'oem_manager' ||
        (getUserData().role == 'dealer_manager' && getUserData().dealershipId == resource.data.dealershipId) ||
        (getUserData().role == 'fleet_client' && getUserData().clientId == resource.data.clientId)
      );
      allow write: if isKhuluAdmin() || getUserData().role == 'oem_manager';
    }

    // Hardware Stock
    match /hardware_stock/{itemId} {
      allow read: if isSignedIn();
      allow write: if isKhuluAdmin();
      
      match /transactions/{txId} {
        allow read: if isSignedIn();
        allow write: if isKhuluAdmin();
      }
    }

    // Engine Protect Events
    match /engine_protect_events/{eventId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn(); // In production, this would be service-account only
    }

    // Onboarding Emails
    match /onboarding_emails/{emailId} {
      allow read, write: if isKhuluAdmin();
    }
  }
}
